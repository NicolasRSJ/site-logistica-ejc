{
  "entities": {
    "User": {
      "title": "User",
      "description": "An escort/driver authorized to retrieve specific encontristas",
      "type": "object",
      "properties": {
        "phone": {
          "type": "string",
          "description": "Phone number used for authentication"
        },
        "name": {
          "type": "string",
          "description": "Full name of the user/escort"
        },
        "assignedEncontristas": {
          "type": "array",
          "description": "List of encontrista IDs assigned to this user"
        }
      },
      "required": ["phone", "name"]
    },
    "Encontrista": {
      "title": "Encontrista",
      "description": "A retreat participant to be picked up and taken home",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the encontrista"
        },
        "phone": {
          "type": "string",
          "description": "Main contact phone number"
        },
        "medication": {
          "type": "string",
          "description": "Medication details or 'Nenhuma'"
        },
        "disability": {
          "type": "string",
          "description": "Disability details or 'Nenhuma'"
        },
        "observations": {
          "type": "string",
          "description": "Additional notes"
        },
        "address": {
          "type": "string",
          "description": "Full street address"
        },
        "complement": {
          "type": "string",
          "description": "Address complement (e.g. apartment number)"
        },
        "additionalPhones": {
          "type": "string",
          "description": "Comma-separated or list of additional contacts"
        }
      },
      "required": ["name", "phone", "address"]
    },
    "Task": {
      "title": "Task",
      "description": "A logistic task created by an administrator for the team",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Short description of what needs to be done"
        },
        "description": {
          "type": "string",
          "description": "Detailed explanation of the task"
        },
        "status": {
          "type": "string",
          "description": "Status of the task ('pending' or 'completed')"
        },
        "assignedTo": {
          "type": "string",
          "description": "ID of the user assigned to this task, or 'all'"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp of creation"
        }
      },
      "required": ["title", "status", "assignedTo"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Users/escorts database"
    },
    "/encontristas/{encontristaId}": {
      "schema": "Encontrista",
      "description": "Encontristas/participants database"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Logistics tasks created by administrators"
    }
  }
}
